<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="FinTech Automation Suite">
    <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>

    <!-- Smoke Tests -->
    <test name="Smoke Tests">

        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <classes>

            <class name="tests.RegisterOpenAccountTest"/>

        </classes>

    </test>

    <!-- Regression Tests -->
    <test name="Regression Tests">

        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>

        <classes>

            <class name="tests.RegisterOpenAccountTest"/>
            <class name="tests.TransferFundsTest"/>

        </classes>

    </test>

</suite>