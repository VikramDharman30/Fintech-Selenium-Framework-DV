<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Suite" parallel="tests" thread-count="3">

    <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>

    <test name="Regression Tests">

        <classes>

            <class name="tests.LoginTest"/>
            <class name="tests.LoginOpenAccountTest"/>
            <class name="tests.RegisterOpenAccountTest"/>
            <class name="tests.RegistrationTest"/>
            <class name="tests.TransferFundsTest"/>

        </classes>

    </test>

</suite>